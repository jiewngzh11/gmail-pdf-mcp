# --- Local development ---
# Set to false for local stdio MCP mode
AZURE_DEPLOYMENT=false

# Default output directory for PDFs (local mode only)
OUTPUT_DIR=C:\Users\jiewn\Documents\MCP_Gmail\output

# OAuth2 callback port (local mode)
OAUTH_PORT=3000

# --- Azure deployment ---
# AZURE_DEPLOYMENT=true
# AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
# AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
# AZURE_STORAGE_CONTAINER_NAME=gmail-pdfs
# PORT=8080
#
# Google OAuth2 credentials (copy from credentials.json > installed)
# Set these as Container App environment variables (or in Key Vault)
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
